/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'none'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'

/sitemap.xml
  Content-Type: application/xml; charset=utf-8

/styles.css
  Cache-Control: public, max-age=86400

/expansion-calculators.js
  Cache-Control: public, max-age=86400

/logo.svg
  Cache-Control: public, max-age=604800
